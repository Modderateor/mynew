local ParticlesContainer = Instance.new("Frame")
ParticlesContainer.Name = "ParticlesContainer"
ParticlesContainer.BackgroundTransparency = 1
ParticlesContainer.Size = UDim2.new(1, 0, 1, 0)
ParticlesContainer.Parent = MainContainer

local function CreateParticle()
    local particle = Instance.new("Frame")
    particle.BackgroundColor3 = Color3.fromRGB(100, 70, 200)
    particle.BorderSizePixel = 0
    particle.Size = UDim2.new(0, math.random(3, 8), 0, math.random(3, 8))
    particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
    particle.ZIndex = -1
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = particle
    
    particle.Parent = ParticlesContainer
    
    task.spawn(function()
        while particle and particle.Parent do
            TweenService:Create(particle, TweenInfo.new(1.5), {
                Position = UDim2.new(math.random(), 0, math.random(), 0),
                BackgroundTransparency = math.random(0, 70) / 100
            }):Play()
            task.wait(1.5)
        end
    end)
end

for i = 1, 15 do
    task.spawn(CreateParticle)
end

local function ShowNotification()
    local notification = Instance.new("Frame")
    notification.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    notification.BorderSizePixel = 0
    notification.Position = UDim2.new(0.5, 0, 0.2, 0)
    notification.Size = UDim2.new(0, 300, 0, 0)
    notification.AnchorPoint = Vector2.new(0.5, 0.5)
    notification.ZIndex = 100
    notification.ClipsDescendants = true
    notification.Parent = CyrusUI

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = notification

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 70, 200)
    stroke.Thickness = 2
    stroke.Parent = notification

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0, 15, 0, 10)
    title.Size = UDim2.new(1, -30, 0, 25)
    title.Font = Enum.Font.GothamBold
    title.Text = "CYRUS HUB"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextSize = 18
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.ZIndex = 101
    title.Parent = notification

    local message = Instance.new("TextLabel")
    message.BackgroundTransparency = 1
    message.Position = UDim2.new(0, 15, 0, 40)
    message.Size = UDim2.new(1, -30, 0, 40)
    message.Font = Enum.Font.Gotham
    message.Text = "Script is down! Join Discord for updates."
    message.TextColor3 = Color3.fromRGB(220, 220, 220)
    message.TextSize = 14
    message.TextWrapped = true
    message.TextXAlignment = Enum.TextXAlignment.Left
    message.ZIndex = 101
    message.Parent = notification

    -- Open animation
    TweenService:Create(
        notification,
        TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        { Size = UDim2.new(0, 300, 0, 90) }
    ):Play()

    task.wait(3)

    -- Close animation
    TweenService:Create(
        notification,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In),
        { Size = UDim2.new(0, 300, 0, 0) }
    ):Play()

    task.wait(0.4)
    notification:Destroy()
end

local function OpenUI()
    TweenService:Create(BlurEffect, TweenInfo.new(0.5), {Size = 10}):Play()
    
    TweenService:Create(MainContainer, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 450, 0, 350)
    }):Play()
    
    task.wait(0.5)
    
    StatusLabel.TextTransparency = 1
    StatusLabel.Visible = true
    
    for i = 1, 10 do
        StatusLabel.TextTransparency = StatusLabel.TextTransparency - 0.1
        task.wait(0.05)
    end
end

local function CloseUI()
    TweenService:Create(StatusLabel, TweenInfo.new(0.2), {
        TextTransparency = 1
    }):Play()
    
    task.wait(0.2)
    
    TweenService:Create(MainContainer, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    }):Play()
    
    TweenService:Create(BlurEffect, TweenInfo.new(0.5), {Size = 0}):Play()
    
    task.wait(0.5)
    CyrusUI:Destroy()
    BlurEffect:Destroy()
end

DiscordButton.MouseButton1Click:Connect(function()
    local originalText = DiscordButton.Text
    local originalColor = DiscordButton.BackgroundColor3
    
    TweenService:Create(DiscordButton, TweenInfo.new(0.2), {
        BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    }):Play()
    
    DiscordButton.Text = "COPYING..."
    
    local discordLink = "https://discord.gg/d3NSzcpRZ5"
    
    local success = pcall(function()
        if setclipboard then
            setclipboard(discordLink)
        elseif writeclipboard then
            writeclipboard(discordLink)
        elseif toclipboard then
            toclipboard(discordLink)
        end
    end)
    
    if success then
        DiscordButton.Text = "LINK COPIED!"
        
        task.spawn(function()
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "CYRUS HUB",
                Text = "Discord link copied to clipboard!",
                Icon = "rbxassetid://9753762463",
                Duration = 3
            })
        end)
    else
        DiscordButton.Text = "OPEN IN BROWSER"
        
        local httpSuccess, httpResult = pcall(function()
            return game:HttpGetAsync("http://localhost:6463/rpc?v=1", true)
        end)
        
        if not httpSuccess then
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "CYRUS HUB",
                Text = "Join: discord.gg/d3NSzcpRZ5",
                Duration = 5
            })
        end
    end
    
    task.wait(1.5)
    
    TweenService:Create(DiscordButton, TweenInfo.new(0.2), {
        BackgroundColor3 = originalColor
    }):Play()
    
    DiscordButton.Text = originalText
end)

DiscordButton.MouseEnter:Connect(function()
    TweenService:Create(DiscordButton, TweenInfo.new(0.2), {
        Size = UDim2.new(0.82, 0, 0, 65)
    }):Play()
end)

DiscordButton.MouseLeave:Connect(function()
    TweenService:Create(DiscordButton, TweenInfo.new(0.2), {
        Size = UDim2.new(0.8, 0, 0, 60)
    }):Play()
end)

CloseButton.MouseButton1Click:Connect(CloseUI)
CloseButton.MouseEnter:Connect(function()
    TweenService:Create(CloseButton, TweenInfo.new(0.2), {
        BackgroundTransparency = 0.7
    }):Play()
end)
CloseButton.MouseLeave:Connect(function()
    TweenService:Create(CloseButton, TweenInfo.new(0.2), {
        BackgroundTransparency = 1
    }):Play()
end)

local dragging = false
local dragStart = Vector2.new(0, 0)
local startPosition = Vector2.new(0, 0)

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = Vector2.new(input.Position.X, input.Position.Y)
        startPosition = Vector2.new(MainContainer.Position.X.Offset, MainContainer.Position.Y.Offset)
    end
end)

Header.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart
        MainContainer.Position = UDim2.new(0, startPosition.X + delta.X, 0, startPosition.Y + delta.Y)
    end
end)

Header.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

OpenUI()
task.wait(0.7)
ShowNotification()

local pulseConnection
pulseConnection = RunService.Heartbeat:Connect(function()
    local time = tick()
    local pulse = math.sin(time * 2) * 0.1 + 0.9
    Title.TextTransparency = 1 - pulse
    
    local colorPulse = math.sin(time * 3) * 0.2 + 0.8
    local r = math.floor(100 * colorPulse + 70)
    local g = math.floor(70 * colorPulse + 30)
    local b = math.floor(200 * colorPulse + 100)
    ContainerStroke.Color = Color3.fromRGB(r, g, b)
end)

if UserInputService.TouchEnabled then
    MainContainer.Size = UDim2.new(0, 400, 0, 350)
end
